{
  "lexicon": 1,
  "id": "app.creaton.forum.getUserKarma",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get PageRank-weighted forum karma for a user.",
      "parameters": {
        "type": "params",
        "required": ["did"],
        "properties": {
          "did": { "type": "string", "format": "did" }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["did", "postKarma", "commentKarma", "totalKarma"],
          "properties": {
            "did": { "type": "string", "format": "did" },
            "postKarma": { "type": "number" },
            "commentKarma": { "type": "number" },
            "totalKarma": { "type": "number" }
          }
        }
      }
    }
  }
}
