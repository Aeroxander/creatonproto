{
  "lexicon": 1,
  "id": "app.creaton.forum.member",
  "defs": {
    "main": {
      "type": "record",
      "description": "A user-authored membership or follow record for a Creaton forum board.",
      "key": "any",
      "record": {
        "type": "object",
        "required": ["board", "createdAt"],
        "properties": {
          "board": {
            "type": "ref",
            "ref": "com.atproto.repo.strongRef"
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
