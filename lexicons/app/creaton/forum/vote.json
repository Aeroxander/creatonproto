{
  "lexicon": 1,
  "id": "app.creaton.forum.vote",
  "defs": {
    "main": {
      "type": "record",
      "description": "A Creaton forum vote on a topic or comment.",
      "key": "any",
      "record": {
        "type": "object",
        "required": ["subject", "direction", "createdAt"],
        "properties": {
          "subject": {
            "type": "ref",
            "ref": "com.atproto.repo.strongRef"
          },
          "direction": {
            "type": "string",
            "knownValues": ["up", "down"]
          },
          "createdAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
